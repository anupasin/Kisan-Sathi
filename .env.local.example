# --- Kisan Sathi environment variables ---
# Copy this file to `.env.local` and fill in your keys.

# Required for the Plant Scan feature (Claude vision — the advice stage).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for scanning.
# Defaults to claude-sonnet-5.
# ANTHROPIC_MODEL=claude-sonnet-5

# Recommended for accurate plant/disease identification (the ID stage).
# Kindwise crop.health API key: https://crop.kindwise.com/ (free tier available).
# If left blank, scanning still works but identifies with Claude vision alone.
CROP_HEALTH_API_KEY=

# Optional but recommended for reliable live mandi prices.
# Free registration at https://data.gov.in/  (My Account -> Generate API key)
# If left blank, the app uses data.gov.in's shared sample key (rate-limited).
DATA_GOV_IN_API_KEY=
