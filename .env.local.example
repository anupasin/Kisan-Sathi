# --- Kisan Sathi environment variables ---
# Copy this file to `.env.local` and fill in your keys.

# Required for the Plant Scan feature (Claude vision).
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for scanning.
# Defaults to claude-sonnet-5.
# ANTHROPIC_MODEL=claude-sonnet-5

# Optional but recommended for reliable live mandi prices.
# Free registration at https://data.gov.in/  (My Account -> Generate API key)
# If left blank, the app uses data.gov.in's shared sample key (rate-limited).
DATA_GOV_IN_API_KEY=
